<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwExceptions="false">

  <targets>
    <target name="console" xsi:type="Console"
            layout="${longdate} ${level:uppercase=true:padding=-5} ${logger:shortName=true} | ${message} ${exception:format=tostring}" />

    <target name="file" xsi:type="File"
            fileName="${basedir}/logs/EmsToRedis-${shortdate}.log"
            archiveAboveSize="10485760"
            archiveFileName="${basedir}/logs/archives/EmsToRedis-${shortdate}-{#}.log"
            archiveNumbering="Sequence"
            maxArchiveFiles="30"
            keepFileOpen="true"
            concurrentWrites="false"
            encoding="utf-8"
            layout="${longdate} ${level:uppercase=true:padding=-5} ${logger:shortName=true} | ${message} ${exception:format=tostring}" />
  </targets>

  <rules>
    <logger name="*" minlevel="Info" writeTo="console" />
    <logger name="*" minlevel="Debug" writeTo="file" />
  </rules>

</nlog>
